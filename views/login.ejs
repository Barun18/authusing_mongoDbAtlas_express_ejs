<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LogIn Page</title>
</head>
<body>
    <div>
        <form method="post" action="/login" class="text-white">
            <input class="mt-6 px-4 rounded-md-3" type="email" name="email" placeholder="email">
            <input class="mt-6 px-4 rounded-md-3" type="password" name="password" placeholder="password">
            <button type="submit">Login</button>
        </form>
    </div>
</body>
</html>