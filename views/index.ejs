<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IndexEJS file</title>
   <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
  <div class="w-full h-screen bg-zinc-900">
   <H3>Create a User</H3>
    <form class="text-white" method="post" action="/create" >
    <input class="px-3 py-2 rounded-md bg-transparent border-2"type="text" placeholder="username" name="username" >
    <input class="px-3 py-2 rounded-md bg-transparent border-2"type="email" placeholder="email" name="email">
    <input class="px-3 py-2 rounded-md bg-transparent border-2"type="password" placeholder="password" name="password">
    <input class="px-3 py-2 rounded-md bg-transparent border-2"type="number" placeholder="age" name="age">
    <input class="px-3 py-2 rounded-md bg-transparent border-2"type="submit" value="Create User"> 
  </form>
   class="px-3 py-2 rounded-md bg-transparent border-2"
  </div>
</body>

</html>